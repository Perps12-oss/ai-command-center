{

  "version": "1.1",

  "coordinate_system": "normalized_uv_0_to_1",

  "interaction_mode": "non_interactive",

  "approved_roles": ["CORE", "METRIC", "STREAM", "CONTROL", "STATUS", "RIBBON", "FEED"],

  "rules": {

    "require_zone_id": true,

    "no_grid_layout": false,

    "internal_grid_only": true,

    "anchor_from_image": false

  },

  "maps": {

    "home": {

      "image": "backgrounds/command_center_bg.jpg",

      "behavior": {

        "parallax": false,

        "zoom": false,

        "scroll": false

      },

      "zones": [

        {

          "id": "action_ribbon",

          "anchor": { "x": 0.5, "y": 0.04 },

          "size": { "w": 0.96, "h": 0.08 },

          "role": ["RIBBON", "CONTROL"]

        },

        {

          "id": "metric_system",

          "anchor": { "x": 0.135, "y": 0.38 },

          "size": { "w": 0.21, "h": 0.40 },

          "role": ["METRIC"]

        },

        {

          "id": "metric_knowledge",

          "anchor": { "x": 0.365, "y": 0.38 },

          "size": { "w": 0.21, "h": 0.40 },

          "role": ["METRIC"]

        },

        {

          "id": "metric_usage",

          "anchor": { "x": 0.635, "y": 0.38 },

          "size": { "w": 0.21, "h": 0.40 },

          "role": ["METRIC"]

        },

        {

          "id": "metric_plugins",

          "anchor": { "x": 0.865, "y": 0.38 },

          "size": { "w": 0.21, "h": 0.40 },

          "role": ["METRIC"]

        },

        {

          "id": "activity_feed",

          "anchor": { "x": 0.5, "y": 0.84 },

          "size": { "w": 0.96, "h": 0.22 },

          "role": ["STREAM", "FEED"]

        }

      ],

      "modules": [

        {

          "type": "ActionRibbon",

          "zone_id": "action_ribbon",

          "props": { "mode": "LIVE_CORE" }

        },

        {

          "type": "MetricCard",

          "id": "SystemStatus",

          "zone_id": "metric_system",

          "data_source": "system.snapshot.cpu",

          "grid_column": 0

        },

        {

          "type": "MetricCard",

          "id": "Knowledge",

          "zone_id": "metric_knowledge",

          "data_source": "note.index_complete",

          "grid_column": 1

        },

        {

          "type": "MetricCard",

          "id": "UsageOverview",

          "zone_id": "metric_usage",

          "data_source": "command.history",

          "grid_column": 2

        },

        {

          "type": "MetricCard",

          "id": "Plugins",

          "zone_id": "metric_plugins",

          "data_source": "plugin.catalog",

          "grid_column": 3

        },

        {

          "type": "ActivityFeedPanel",

          "zone_id": "activity_feed",

          "data_source": "telemetry_events"

        }

      ],

      "motion_rules": {}

    }

  }

}
