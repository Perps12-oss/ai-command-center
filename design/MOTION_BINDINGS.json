{
  "version": "1.1",
  "allowed_sources": [
    "system.snapshot",
    "telemetry_events",
    "command.history",
    "ollama.status",
    "note.index_progress",
    "chat.started",
    "chat.complete",
    "ui.command"
  ],
  "bindings": {
    "ActionRibbon": {
      "required": ["system.snapshot"],
      "optional": ["telemetry_events"],
      "refresh": "on_event",
      "outputs": {
        "pulse_rate": "system.snapshot.cpu_percent",
        "glow_intensity": "telemetry_events.rate"
      },
      "fallback": {
        "pulse_rate": 0.8,
        "glow_intensity": 0.3
      }
    },
    "ActivityFeedPanel": {
      "required": ["telemetry_events"],
      "optional": ["command.history", "system.events"],
      "refresh": "on_event",
      "fallback": {
        "events": []
      }
    },
    "HeroPanel": {
      "required": ["system.snapshot"],
      "optional": ["telemetry_events"],
      "refresh": "on_event",
      "outputs": {
        "pulse_rate": "system.snapshot.cpu_percent",
        "glow_intensity": "telemetry_events.rate",
        "segment_activity": [
          "system.snapshot.cpu_percent",
          "system.snapshot.ram_percent",
          "system.snapshot.model_load"
        ]
      },
      "fallback": {
        "pulse_rate": 0.8,
        "glow_intensity": 0.3,
        "segment_activity": [0, 0, 0]
      }
    },
    "MetricCard.SystemStatus": {
      "required": ["system.snapshot.cpu_percent", "system.snapshot.health"],
      "optional": ["ollama.status.online"],
      "refresh": "on_event",
      "fallback": {
        "cpu_percent": "—",
        "health": "unknown",
        "pill": "offline"
      }
    },
    "MetricCard.UsageOverview": {
      "required": ["command.history"],
      "optional": ["telemetry_events"],
      "refresh": "on_event",
      "fallback": {
        "commands": 0,
        "tokens": "—",
        "sessions": 0
      }
    },
    "MetricCard.Knowledge": {
      "required": ["note.index_complete"],
      "optional": [],
      "refresh": "on_event",
      "fallback": {
        "indexed_files": 0,
        "vault_files": 0
      }
    },
    "MetricCard.Plugins": {
      "required": ["plugin.catalog"],
      "optional": [],
      "refresh": "on_event",
      "fallback": {
        "enabled": 0,
        "installed": 0
      }
    },
    "EventStreamRibbon": {
      "required": ["telemetry_events"],
      "optional": ["system.events"],
      "refresh": "on_event",
      "fallback": {
        "events": []
      }
    },
    "CommandFlowTrail": {
      "required": ["command.history"],
      "optional": ["ui.command"],
      "refresh": "on_event",
      "fallback": {
        "commands": []
      }
    },
    "SystemHeartbeat": {
      "required": ["system.snapshot.cpu_percent"],
      "optional": [],
      "refresh": "on_event",
      "fallback": {
        "rate": 0.5
      }
    },
    "StatusFluxBarGrid": {
      "required": ["system.snapshot"],
      "optional": [],
      "refresh": "on_event",
      "fallback": {
        "cpu": 0,
        "ram": 0,
        "model_load": 0,
        "network": 0
      }
    },
    "ActivityPulseField": {
      "required": ["telemetry_events"],
      "optional": ["system.events"],
      "refresh": "on_event",
      "fallback": {
        "density": "low"
      }
    }
  }
}
