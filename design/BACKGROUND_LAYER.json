{

  "version": "1.3",

  "layer_stack": {

    "order": [

      "L1_BACKGROUND_CANVAS",

      "L2_DEPTH_LAYER",

      "L3_MOTION_LAYER",

      "L4_UI_FOREGROUND"

    ],

    "z_index": {

      "background": 0,

      "depth": 10,

      "motion": 20,

      "ui": 30,

      "modal": 40

    }

  },

  "approved_modes": [

    "STATIC_GRID",

    "DARK_CANVAS",

    "NEURAL_MAP",

    "ABSTRACT_SYSTEM_FLOW",

    "MINIMAL_FLAT"

  ],

  "rules": {

    "one_background_per_page": true,

    "background_before_ui_compile": true,

    "no_component_background_override": true,

    "motion_max_opacity": 0.85,

    "background_non_interactive": true,

    "allowed_modulation_sources": [

      "system.snapshot",

      "ollama.status",

      "telemetry_events"

    ]

  },

  "global_wallpaper": {

    "mode": "ABSTRACT_SYSTEM_FLOW",

    "image": "backgrounds/command_center_bg.jpg",

    "image_mode": "exact",

    "overlay_tint": "none",

    "vignette": false,

    "noise": "none",

    "blur": {

      "enabled": true,

      "radius": 12,

      "vignette_dim": 0.15

    }

  },

  "default_background": {

    "inherit": "global_wallpaper"

  },

  "pages": {

    "home": {

      "inherit": "global_wallpaper",

      "modulation": "disabled",

      "scroll": "locked",

      "parallax": false

    },

    "system": {

      "inherit": "global_wallpaper"

    },

    "chat": {

      "inherit": "global_wallpaper"

    },

    "notes": {

      "inherit": "global_wallpaper"

    },

    "plugins": {

      "inherit": "global_wallpaper"

    },

    "settings": {

      "inherit": "global_wallpaper"

    }

  },

  "modulation_bindings": {

    "system.snapshot.health": {

      "healthy": { "tint_step": 0, "desaturate": false },

      "degraded": { "tint_step": 1, "desaturate": false },

      "stressed": { "tint_step": 2, "desaturate": false },

      "unknown": { "tint_step": 1, "desaturate": true }

    },

    "system.snapshot.cpu_percent": {

      "noise_level": "linear_0_100"

    },

    "ollama.status.online": {

      "false": { "desaturate": true, "dim": 0.25 },

      "true": { "desaturate": false, "dim": 0.0 }

    },

    "telemetry_events": {

      "flicker_amplitude": 0.03,

      "flicker_max_hz": 0.5

    }

  },

  "tint_palette": [

    "#12131C",

    "#0B0C15",

    "#080910",

    "#06070D"

  ]

}

